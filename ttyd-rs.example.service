[Unit]
Description=ttyd-rs - Share terminal over the web
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/ttyd-rs
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
KillMode=progress

# Security hardening
ReadWritePaths=/var/log/ttyd-rs

# Resource limits
LimitNOFILE=512

[Install]
WantedBy=multi-user.target
